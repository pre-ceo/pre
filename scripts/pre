#!/usr/bin/env python3
"""pre — 统一 CLI 入口 (子命令 dispatcher).

子命令:
  init <cwd>           在指定目录初始化 claude agent (= pre_init.py)
  migrate              迁移老 pre_rule/agents/<dir>/ 到 pointer 格式 (= pre_migrate.py)
  repair [cwd]         强制重写 cwd agent_config + .claude hook (= pre_repair.py)
  update               git pull pre + pre_ui, uv sync, bus restart (= pre_update.py)
  spawn <id>           起 tmux session + 通知 master rediscover (= spawn_agent.sh)
  rm <id|dir>          删除 pre_rule/agents/<dir>/ 索引 (不动 cwd)
  list                 列所有 discover_agents 结果 + 状态
  status               整体组件状态 (bus subsystems + cron schedules + wiring)
  usage <action>       usage subsystem (sys_* tmux + cron probe):
                       install — spawn sys_* + ensure schedule + verify
  teach [target]       发 pre 教程给 agent (target=me|<agent_id>, 走 bus + 写 cwd/pre/teach.md)
  check-mcp            诊 sibling MCP 健康 (shim 版本 / env token 绑定 / 每 agent 后子进程状态)
  bus <action> [tgt]   管理 master/node/ui/cron daemon (= bus_ctl.sh):
                       start | stop | restart | status | logs | attach | sync

每个子命令支持 --help (bus 走 bus_ctl.sh, 用 `pre bus` 看 usage).

shim 由 scripts/install.sh 安装到 $ARG_BIN_DIR/pre (默认 ~/.local/bin/pre).
"""
import argparse
import asyncio
import json
import os
import shutil
import subprocess
import sys

_HERE = os.path.dirname(os.path.abspath(__file__))
_PRE_ROOT = os.path.dirname(_HERE)
sys.path.insert(0, _HERE)
sys.path.insert(0, os.path.join(_PRE_ROOT, "src"))


C_CYAN = "\033[36m"
C_YELLOW = "\033[33m"
C_BLUE = "\033[34m"
C_MAGENTA = "\033[35m"
C_DIM = "\033[2m"
C_RESET = "\033[0m"


def _cmd_init(rest):
    import pre_init
    sys.argv = ["pre init"] + rest
    return pre_init.main()


def _cmd_migrate(rest):
    import pre_migrate
    sys.argv = ["pre migrate"] + rest
    return pre_migrate.main()


def _cmd_repair(rest):
    import pre_repair
    sys.argv = ["pre repair"] + rest
    return pre_repair.main()


def _cmd_update(rest):
    import pre_update
    sys.argv = ["pre update"] + rest
    return pre_update.main()


def _cmd_spawn(rest):
    spawn_sh = os.path.join(_HERE, "spawn_agent.sh")
    return subprocess.call(["bash", spawn_sh] + rest)


def _cmd_bus(rest):
    bus_sh = os.path.join(_HERE, "bus_ctl.sh")
    return subprocess.call(["bash", bus_sh] + rest)


def _cmd_teach(rest):
    import pre_teach
    sys.argv = ["pre teach"] + rest
    return pre_teach.main()


def _cmd_check_mcp(rest):
    import check_mcp_status
    sys.argv = ["pre check-mcp"] + rest
    return check_mcp_status.main()


def _resolve_rule_root() -> str:
    from config import RULE_ROOT
    return os.environ.get("PRE_RULE_ROOT") or RULE_ROOT


def _find_agent_dir(agents_dir: str, target: str):
    """target 可以是 dir_name (Users-...) 或 agent_id (local.xxx.yyy).
    返 (agent_pre_dir, source) 或 (None, None)."""
    candidate = os.path.join(agents_dir, target)
    if os.path.isdir(candidate):
        return candidate, "dir-name"

    orphan_prefix = "local.cli-claude-code-local.orphan-"
    for name in sorted(os.listdir(agents_dir)):
        d = os.path.join(agents_dir, name)
        if not os.path.isdir(d):
            continue
        ptr = os.path.join(d, "agent_pointer.json")
        if os.path.isfile(ptr):
            try:
                with open(ptr) as f:
                    pdata = json.load(f)
            except (OSError, json.JSONDecodeError):
                pdata = {}
            if pdata.get("agent_id") == target:
                return d, "pointer"
        elif target.startswith(orphan_prefix):
            # orphan agent_id 的 suffix 就是 dir_name
            if name == target[len(orphan_prefix):]:
                return d, "orphan-id"
    return None, None


def _cmd_rm(rest):
    p = argparse.ArgumentParser(
        prog="pre rm",
        description="Remove pre_rule/agents/<dir>/ index. Does NOT touch agent cwd.",
    )
    p.add_argument("target", help="agent_id (e.g. local.cli-claude-code-local.pre) "
                                  "or dir name (e.g. Users-user-cursor-pre)")
    p.add_argument("-y", "--yes", action="store_true", help="skip confirmation")
    args = p.parse_args(rest)

    agents_dir = os.path.join(_resolve_rule_root(), "agents")
    if not os.path.isdir(agents_dir):
        print(f"{C_YELLOW}agents dir not found: {agents_dir}{C_RESET}")
        return 1

    d, source = _find_agent_dir(agents_dir, args.target)
    if d is None:
        print(f"{C_YELLOW}no pre_rule/agents/ entry matches '{args.target}'{C_RESET}")
        return 1

    cwd_hint = ""
    ptr = os.path.join(d, "agent_pointer.json")
    if os.path.isfile(ptr):
        try:
            with open(ptr) as f:
                cwd_hint = json.load(f).get("cwd", "")
        except (OSError, json.JSONDecodeError):
            pass

    print(f"{C_MAGENTA}━━━ pre rm ({source}) ━━━{C_RESET}")
    print(f"{C_BLUE}target index:{C_RESET} {d}")
    if cwd_hint:
        print(f"{C_DIM}pointer.cwd: {cwd_hint} (NOT deleted){C_RESET}")
    else:
        print(f"{C_DIM}no pointer (orphan dir){C_RESET}")

    if not args.yes:
        try:
            ans = input(f"{C_YELLOW}type 'delete' to confirm: {C_RESET}").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return 1
        if ans != "delete":
            print(f"{C_DIM}aborted{C_RESET}")
            return 1

    try:
        shutil.rmtree(d)
        print(f"{C_CYAN}removed {d}{C_RESET}")
        if cwd_hint:
            print(f"{C_DIM}note: {cwd_hint}/pre/ untouched — remove manually if you want.{C_RESET}")
        return 0
    except OSError as e:
        print(f"{C_YELLOW}rm failed: {e}{C_RESET}")
        return 1


def _cmd_list(rest):
    p = argparse.ArgumentParser(prog="pre list",
                                description="List discovered agents with status.")
    p.add_argument("--failed-only", action="store_true")
    p.add_argument("--ok-only", action="store_true")
    p.add_argument("--driver", default=None,
                   choices=["claude", "codex", "gemini"],
                   help="filter by cli driver (default: all)")
    args = p.parse_args(rest)

    from drivers.cli_claude_code_local.driver import CliClaudeCodeLocalDriver
    from drivers.cli_codex_local.driver import CliCodexLocalDriver
    _DRIVERS = [CliClaudeCodeLocalDriver, CliCodexLocalDriver]
    try:
        from drivers.cli_gemini_local.driver import CliGeminiLocalDriver
        _DRIVERS.append(CliGeminiLocalDriver)
    except ImportError:
        pass

    async def _run():
        all_specs = []
        for cls in _DRIVERS:
            drv = cls()
            await drv.init({"node_id": os.environ.get("PRE_NODE_ID", "local")})
            try:
                specs = await drv.discover_agents()
            except Exception as e:
                print(f"{C_YELLOW}[warn]{C_RESET} {cls.__name__}.discover failed: {e}")
                continue
            for s in specs:
                # 标 cli 供 filter 用 (metadata 已带 cli, 但失败 spec 可能也带)
                s.metadata.setdefault("_driver_cli", drv.cli_name)
            all_specs.extend(specs)
        return all_specs

    specs = asyncio.run(_run())
    if args.driver:
        specs = [s for s in specs
                 if s.metadata.get("_driver_cli") == args.driver
                 or s.metadata.get("cli") == args.driver]
    if args.failed_only:
        specs = [s for s in specs if s.metadata.get("status") != "ok"]
    elif args.ok_only:
        specs = [s for s in specs if s.metadata.get("status") == "ok"]

    if not specs:
        print(f"{C_DIM}no agents discovered{C_RESET}")
        return 0

    for s in specs:
        st = s.metadata.get("status", "?")
        color = C_CYAN if st == "ok" else C_YELLOW
        cli = s.metadata.get("cli") or s.metadata.get("_driver_cli") or "?"
        print(f"{color}[{st}]{C_RESET} {s.agent_id} {C_DIM}({cli}){C_RESET}")
        if st == "ok":
            print(f"      cwd:  {s.metadata.get('cwd')}")
            print(f"      tmux: {s.metadata.get('tmux_session')}  "
                  f"mode: {s.metadata.get('mode')}  role: {s.role}")
        else:
            print(f"      reason: {s.metadata.get('failure_reason')}")
            print(f"      hint:   {s.metadata.get('failure_hint')}")
    return 0


def _print_cron_status():
    """cron schedules 状态 — master 内嵌 cron loop 读 pre_rule/cron/schedules.json."""
    rule_root = _resolve_rule_root()
    sched_path = os.path.join(rule_root, "cron", "schedules.json")
    print(f"{C_MAGENTA}━━━ cron schedules ━━━{C_RESET}")
    if not os.path.isfile(sched_path):
        print(f"{C_DIM}[no schedules]  {sched_path} not found{C_RESET}")
        return
    try:
        with open(sched_path, encoding="utf-8") as f:
            doc = json.load(f)
        schedules = doc.get("schedules") or []
    except (OSError, json.JSONDecodeError) as e:
        print(f"{C_YELLOW}[error]{C_RESET}     {sched_path}: {e}")
        return
    total = len(schedules)
    enabled = sum(1 for s in schedules if s.get("enabled", True))
    print(f"{C_CYAN}[schedules]{C_RESET} {enabled} enabled / {total} total "
          f"{C_DIM}({sched_path}){C_RESET}")
    for s in schedules:
        sid = s.get("id", "?")
        en = s.get("enabled", True)
        typ = s.get("type", "?")
        node = s.get("target_node", "local")
        if typ == "interval":
            spec = f"every={s.get('every_seconds')}s"
        elif typ == "daily":
            spec = f"at={s.get('at', '?')}"
        else:
            spec = f"type={typ}"
        flag = f"{C_CYAN}●{C_RESET}" if en else f"{C_DIM}○{C_RESET}"
        print(f"  {flag} {sid}  {C_DIM}({spec}, node={node}){C_RESET}")


def _print_wiring_status():
    """wiring 状态: ~/.local/bin shims + ~/.pre/env tokens + ~/.claude.json mcp 注册."""
    print(f"{C_MAGENTA}━━━ wiring ━━━{C_RESET}")

    shim_dir = os.path.expanduser("~/.local/bin")
    expected_shims = ["pre", "pre-mcp", "pre-tool-use", "pre-stop-hook"]
    shim_missing = [s for s in expected_shims
                    if not (os.path.isfile(os.path.join(shim_dir, s))
                            and os.access(os.path.join(shim_dir, s), os.X_OK))]
    if not shim_missing:
        print(f"{C_CYAN}[shims]{C_RESET}     ok  {C_DIM}({len(expected_shims)} in {shim_dir}){C_RESET}")
    else:
        print(f"{C_YELLOW}[shims]{C_RESET}     missing: {', '.join(shim_missing)} "
              f"{C_DIM}— run scripts/install.sh{C_RESET}")

    env_path = os.path.expanduser("~/.pre/env")
    expected_envs = ["PRE_NODE_SECRET", "PRE_MCP_SECRET", "PRE_HOOK_SECRET",
                     "PRE_GUI_SECRET", "PRE_OPERATOR_SECRET"]
    env_present, env_missing = [], list(expected_envs)
    if os.path.isfile(env_path):
        try:
            content = open(env_path, encoding="utf-8").read()
            lines = content.splitlines()
            env_present = [e for e in expected_envs
                           if any(line.strip().startswith(f"{e}=") for line in lines)]
            env_missing = [e for e in expected_envs if e not in env_present]
        except OSError:
            pass
    if not env_missing:
        print(f"{C_CYAN}[env]{C_RESET}       ok  {C_DIM}({len(env_present)}/{len(expected_envs)} tokens, {env_path}){C_RESET}")
    elif not env_present:
        print(f"{C_YELLOW}[env]{C_RESET}       {env_path} missing or no tokens "
              f"{C_DIM}— run scripts/pre_token.py issue{C_RESET}")
    else:
        print(f"{C_YELLOW}[env]{C_RESET}       partial — missing: {', '.join(env_missing)} "
              f"{C_DIM}({env_path}){C_RESET}")

    claude_json = os.path.expanduser("~/.claude.json")
    if not os.path.isfile(claude_json):
        print(f"{C_YELLOW}[mcp]{C_RESET}       {claude_json} not found")
        return
    try:
        with open(claude_json, encoding="utf-8") as f:
            data = json.load(f)
        servers = data.get("mcpServers", {})
        if isinstance(servers, dict) and isinstance(servers.get("pre"), dict):
            cmd = servers["pre"].get("command", "?")
            print(f"{C_CYAN}[mcp]{C_RESET}       ok  {C_DIM}(mcpServers.pre command={cmd}){C_RESET}")
        else:
            print(f"{C_YELLOW}[mcp]{C_RESET}       mcpServers.pre missing "
                  f"{C_DIM}— run scripts/install_mcp_registration.py{C_RESET}")
    except (OSError, json.JSONDecodeError) as e:
        print(f"{C_YELLOW}[mcp]{C_RESET}       {claude_json} unreadable: {e}")


def _ensure_usage_schedule(sched_path: str) -> tuple[str, str]:
    """确保 schedules.json 含 pre_usage_probe entry.

    返 (status, detail):
      ("exists",  path)  — entry 已在, 不动
      ("added",   path)  — 文件存在但缺 entry, append
      ("created", path)  — 文件不存在, 全新写
      ("error",   msg)   — read/write 失败
    """
    entry = {
        "id": "pre_usage_probe",
        "_desc": "15min 抓 sys_claude/sys_gemini/sys_codex 配额; 同时做 sys_* 保活.",
        "type": "interval",
        "every_seconds": 900,
        "enabled": True,
        "target_node": "local",
        "cmd": ["uv", "run", "python", "scripts/usage_probe_once.py"],
        "cwd": _PRE_ROOT,
        "env": {"PRE_MASTER_URL": "http://127.0.0.1:19500"},
    }
    try:
        os.makedirs(os.path.dirname(sched_path), exist_ok=True)
    except OSError as e:
        return "error", f"mkdir failed: {e}"

    if not os.path.isfile(sched_path):
        doc = {"version": 1, "schedules": [entry]}
        try:
            with open(sched_path, "w", encoding="utf-8") as f:
                json.dump(doc, f, indent=2, ensure_ascii=False)
                f.write("\n")
        except OSError as e:
            return "error", f"write failed: {e}"
        return "created", sched_path

    try:
        with open(sched_path, encoding="utf-8") as f:
            doc = json.load(f)
        if not isinstance(doc, dict):
            return "error", f"{sched_path} root is not object"
        if not isinstance(doc.get("schedules"), list):
            doc["schedules"] = []
    except (OSError, json.JSONDecodeError) as e:
        return "error", f"read failed: {e}"

    for s in doc["schedules"]:
        if isinstance(s, dict) and s.get("id") == "pre_usage_probe":
            return "exists", sched_path

    doc["schedules"].append(entry)
    try:
        with open(sched_path, "w", encoding="utf-8") as f:
            json.dump(doc, f, indent=2, ensure_ascii=False)
            f.write("\n")
    except OSError as e:
        return "error", f"write failed: {e}"
    return "added", sched_path


def _cmd_usage(rest):
    """pre usage <action> — usage subsystem 运维 (sys_* tmux + cron probe).

    Actions:
      install   一次性装齐 usage subsystem (sys_claude/codex/gemini tmux +
                确认 cron schedule + 默认立即 probe verify).
    """
    if not rest or rest[0] in ("-h", "--help", "help"):
        print("usage: pre usage <action> [args...]")
        print()
        print("actions:")
        print("  install   spawn sys_claude/codex/gemini tmux + verify cron schedule + probe")
        print()
        print("`pre usage install --help` for action-level flags.")
        return 0
    action = rest[0]
    if action == "install":
        return _do_usage_install(rest[1:])
    print(f"unknown usage action: {action}", file=sys.stderr)
    return 2


def _do_usage_install(rest):
    """install: 起 sys_* tmux + 确认 cron schedule + 立即 probe."""
    p = argparse.ArgumentParser(
        prog="pre usage install",
        description="装齐 usage subsystem: spawn sys_claude/codex/gemini tmux, "
                    "确认 cron schedule, 立即跑一次 probe verify.",
    )
    p.add_argument("--provider", action="append", default=None,
                   choices=["claude", "codex", "gemini"],
                   help="只装某个 provider (可重复); 不传则装全部 3 家")
    p.add_argument("--force-respawn", action="store_true",
                   help="即使 sys_* tmux 已存在也 kill 重起")
    p.add_argument("--no-probe", action="store_true",
                   help="装完不立即 trigger probe verify (默认会跑一次)")
    args = p.parse_args(rest)
    providers = args.provider or ["claude", "codex", "gemini"]

    print(f"{C_MAGENTA}━━━ pre usage install ━━━{C_RESET}")
    print(f"{C_DIM}providers: {','.join(providers)}{C_RESET}\n")

    # 1. master 必须在跑 (cron loop 嵌在 master 进程里)
    bus_sh = os.path.join(_HERE, "bus_ctl.sh")
    bus_r = subprocess.run(["bash", bus_sh, "status"],
                           capture_output=True, text=True, timeout=10)
    master_ok = ("master port:" in bus_r.stdout and "listening" in bus_r.stdout)
    if master_ok:
        print(f"{C_CYAN}[ok]{C_RESET}      bus master alive (:19500 listening)")
    else:
        print(f"{C_YELLOW}[warn]{C_RESET}    bus master 不像在跑 — 先跑 `pre bus start`, "
              f"否则 cron loop 不跑")

    # 2. cron schedule ensure — 没有就 append/create, 已有就跳过.
    #    master 内嵌 cron 30s tick hot-reload, 不用重启.
    rule_root = _resolve_rule_root()
    sched_path = os.path.join(rule_root, "cron", "schedules.json")
    status, detail = _ensure_usage_schedule(sched_path)
    if status == "exists":
        print(f"{C_CYAN}[ok]{C_RESET}      cron schedule pre_usage_probe present "
              f"{C_DIM}({sched_path}){C_RESET}")
    elif status == "added":
        print(f"{C_CYAN}[added]{C_RESET}   cron schedule pre_usage_probe written "
              f"{C_DIM}({sched_path}){C_RESET}")
    elif status == "created":
        print(f"{C_CYAN}[created]{C_RESET} {sched_path} with pre_usage_probe entry")
    else:
        print(f"{C_YELLOW}[warn]{C_RESET}    schedule write failed: {detail}")

    # 3. spawn sys_* tmux (复用 usage_probe_once._respawn)
    print()
    print(f"{C_MAGENTA}━━ spawn sys_* tmux ━━{C_RESET}")
    try:
        from usage_probe_once import _respawn  # noqa: E402
    except ImportError as e:
        print(f"{C_YELLOW}[error]{C_RESET}   import usage_probe_once 失败: {e}")
        return 1

    all_spawned = True
    for prov in providers:
        ok, msg = _respawn(prov, force_kill=args.force_respawn)
        if ok:
            print(f"{C_CYAN}[ok]{C_RESET}      sys_{prov}: {msg}")
        else:
            print(f"{C_YELLOW}[fail]{C_RESET}    sys_{prov}: {msg}")
            all_spawned = False

    # 4. 立即 trigger 一次 probe verify (除非 --no-probe)
    if not args.no_probe:
        print()
        print(f"{C_MAGENTA}━━ verify: 立即跑一次 probe ━━{C_RESET}")
        env = os.environ.copy()
        env.setdefault("PRE_MASTER_URL", "http://127.0.0.1:19500")
        probe_script = os.path.join(_HERE, "usage_probe_once.py")
        try:
            r = subprocess.run(
                ["uv", "run", "python", probe_script],
                env=env, cwd=_PRE_ROOT, capture_output=True, text=True, timeout=90,
            )
            lines = (r.stdout or "").splitlines()
            tail = lines[-10:] if len(lines) > 10 else lines
            for line in tail:
                print(f"  {C_DIM}{line}{C_RESET}")
            if r.returncode != 0:
                print(f"{C_YELLOW}[warn]{C_RESET}    probe exited rc={r.returncode}")
                if r.stderr:
                    print(f"  {C_DIM}stderr: {r.stderr[-200:]}{C_RESET}")
        except (subprocess.TimeoutExpired, FileNotFoundError) as e:
            print(f"{C_YELLOW}[warn]{C_RESET}    probe failed: {e}")

    print()
    print(f"{C_CYAN}━━━ done ━━━{C_RESET}")
    if not all_spawned:
        print(f"{C_DIM}部分 sys_* 没起来, 检查 ~/.pre/sys_workdir 或 spawn.rc{C_RESET}")
        return 1
    return 0


def _cmd_status(rest):
    """显示 pre 整体组件状态: subsystems (bus) + cron schedules + wiring."""
    p = argparse.ArgumentParser(
        prog="pre status",
        description="Show overall pre status: subsystems (master/node/ui/cron tmux + "
                    "ports), cron schedules, wiring (shims/env/mcp registration).",
    )
    p.add_argument("--no-wiring", action="store_true",
                   help="跳过 shim/env/mcp 检查, 只看运行时 subsystems + cron")
    p.add_argument("--no-cron", action="store_true",
                   help="跳过 cron schedules block")
    args = p.parse_args(rest)

    bus_sh = os.path.join(_HERE, "bus_ctl.sh")
    rc = subprocess.call(["bash", bus_sh, "status"])
    if rc != 0:
        return rc

    if not args.no_cron:
        print()
        _print_cron_status()
    if not args.no_wiring:
        print()
        _print_wiring_status()

    return 0


_COMMANDS = {
    "init": _cmd_init,
    "migrate": _cmd_migrate,
    "repair": _cmd_repair,
    "update": _cmd_update,
    "spawn": _cmd_spawn,
    "rm": _cmd_rm,
    "list": _cmd_list,
    "bus": _cmd_bus,
    "status": _cmd_status,
    "usage": _cmd_usage,
    "teach": _cmd_teach,
    "check-mcp": _cmd_check_mcp,
}


def _usage():
    print("usage: pre <command> [args...]")
    print()
    print("commands:")
    print("  init <cwd>           initialize a claude agent in cwd (idempotent)")
    print("  migrate              migrate legacy pre_rule/agents/ to pointer format")
    print("  repair [cwd]         force-rewrite agent_config + .claude hook in cwd")
    print("  update               git pull pre + pre_ui, uv sync, bus restart")
    print("  spawn <id>           start tmux session for agent_id + notify master")
    print("  rm <id|dir>          remove pre_rule/agents/<dir>/ index (cwd untouched)")
    print("  list                 list all discovered agents with status")
    print("  status               overall component status (subsystems + cron + wiring)")
    print("  usage <action>       usage subsystem (sys_* tmux + cron probe)")
    print("                       actions: install")
    print("  teach [target]       send pre tutorial to agent (target=me|<agent_id>)")
    print("  check-mcp            diagnose sibling MCP health (shim / env / per-agent)")
    print("  bus <action> [tgt]   manage master/node/ui/cron daemons")
    print("                       actions: start|stop|restart|status|logs|attach|sync")
    print()
    print("each command supports --help (e.g. pre init --help, pre bus)")


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        _usage()
        return 0
    cmd = sys.argv[1]
    rest = sys.argv[2:]
    fn = _COMMANDS.get(cmd)
    if not fn:
        print(f"unknown command: {cmd}\n", file=sys.stderr)
        _usage()
        return 2
    rc = fn(rest)
    return rc if rc is not None else 0


if __name__ == "__main__":
    sys.exit(main())
