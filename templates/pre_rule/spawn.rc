# RESP=$(curl -s --max-time 5 https://ipinfo.io/json 2>/dev/null || echo "")
# if [ -z "$RESP" ]; then
#   echo "[spawn.rc] WARN: ip lookup unreachable (proxy down?)"
# else
#   COUNTRY=$(echo "$RESP" | grep -o '"country":[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
#   IP=$(echo "$RESP" | grep -o '"ip":[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
#   echo "[spawn.rc] egress: ip=$IP country=$COUNTRY"
#   if [ "$COUNTRY" != "$EXPECTED_COUNTRY" ]; then
#     echo "[spawn.rc] FATAL: egress not $EXPECTED_COUNTRY (got '$COUNTRY'), abort cli start"
#     sleep 5
#     exit 1
#   fi
